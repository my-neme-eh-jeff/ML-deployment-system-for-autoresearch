# Copy to .env (gitignored) and fill in.
# webreel substitutes ${VAR} in config strings from the process env at record time.

# Cluster URLs — run `make gke-status` to print current values.
MLFLOW_URL=http://34.180.20.197:5000
KFP_URL=http://34.93.2.209
ARGOCD_URL=http://34.100.246.237

# ArgoCD password — `kubectl get secret -n argocd argocd-initial-admin-secret -o jsonpath='{.data.password}' | base64 -d`
# ROTATE THIS AFTER RECORDING — the password will be typed on camera as keystroke HUD,
# so anything in the final video could be lifted from a slow-frame screenshot.
ARGOCD_PASSWORD=

# GitHub repo for the PRs scene.
GITHUB_OWNER=my-neme-eh-jeff
GITHUB_REPO=ML-deployment-system-for-autoresearch
