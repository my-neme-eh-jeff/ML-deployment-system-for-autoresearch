FROM python:3.12-slim
# Pre-install all KFP pipeline dependencies so they live in image layers,
# not in the container's writable layer (ephemeral storage).
# GKE Autopilot limits ephemeral storage to 1Gi by default — runtime pip
# installs of sklearn + mlflow + pandas exceed this.
RUN pip install --no-cache-dir \
    pandas==2.3.3 \
    scikit-learn==1.8.0 \
    mlflow==3.10.1 \
    gcsfs==2025.7.0 \
    kfp==2.16.0
